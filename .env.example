# ---------------------------------------------------------------
# yt-dlp-webgui environment configuration
# Copy this file to .env and fill in all values before running.
# .env is gitignored and must never be committed.
# ---------------------------------------------------------------

# --- Server ---
APP_ENV=production
APP_ADDR=:8080

# --- Authentication ---
# Username for the control panel login
APP_USERNAME=admin

# Argon2id hash of your password.
# Generate with: ./scripts/hash-password.sh yourpassword
# Or run: go run ./cmd/hashpw yourpassword
APP_PASSWORD_HASH=

# --- Session ---
# Long random secret for signing session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
SESSION_TTL=24h

# --- Download settings ---
# How long an expiring download link remains valid
DOWNLOAD_TTL=1h

# Maximum number of concurrent jobs (1 = queue, no parallelism)
MAX_ACTIVE_JOBS=1

# --- Paths ---
DATA_DIR=./data
DOWNLOADS_DIR=./data/downloads
CUSTOM_RUNTIME_DIR=./data/runtime/custom
UPLOADS_DIR=./data/uploads
LOGS_DIR=./data/logs

# --- Binaries ---
# Path to the official yt-dlp executable inside the container or host
OFFICIAL_YTDLP_PATH=/usr/local/bin/yt-dlp

# Python binary used to run custom source ZIP runtime
PYTHON_BIN=python3

# ffmpeg and ffprobe paths
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
